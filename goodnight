#!/usr/bin/bash

# This script is used at the end of work, it syncs all work with google drive  
# It also checks for running jobs in both the local machine and remote clusters
# if nothing of the local machine is required (no jobs running) it shuts down

# back up in google drive
gdrivefolders=("/home/vinicp/Chem" "/home/vinicp/Documents" "/home/vinicp/physics" )
gitfolders=("/home/vinicp/Repos/chemgui" "/home/vinicp/Repos/chemgui-openbabel" "/home/vinicp/Chem/datasets" "/home/vinicp/Chem/janus-crown" "/home/vinicp/Chem/perichromic-probes" )

# create log files
touch tmp.log
touch tmp.gdrive.log

# sync google drive
for i in "${gdrivefolders[@]}"
do 
    cd $i 
    gdrive push >> tmp.gdrive.log
done 

# sync taskwarrior 
task sync >> tmp.log

# for every git repositary, check if it has files not staged/commited
# sync google drive
for j in "${gitfolders[@]}"
do 
    echo "\nChecking $j" >> tmp.log
    cd $j 
    # no added files
    git diff --exit-code >> tmp.log

    # no committed files 
    git diff --cached --exit-code >> tmp.log

    # commited but not pushed 

    # no untracked files (do i need this?)
done 


# check for jobs that have ended or not and update status 

# print the log file 
cat tmp.gdrive.log | grep INFO >> tmp.log 
cat tmp.log 

rm tmp.log tmp.gdrive.log


